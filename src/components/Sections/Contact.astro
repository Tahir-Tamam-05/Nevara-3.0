---
/**
 * Section 8 — Contact / Assessment request.
 * Submits via Formspree. Fallback mailto link for visitors who prefer email.
 */
import { contactEmail } from '@lib/content';

const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xdaykekg';
---

<section id="contact" class="contact-section section-pad" aria-labelledby="contact-heading">
  <div class="container-site contact-grid">
    <div class="reveal">
      <p class="label-caps kicker">Request an assessment</p>
      <h2 id="contact-heading" class="font-display contact-headline">
        Tell us about <em>your site.</em>
      </h2>
      <p class="contact-lede">
        A lake, a forest, a wetland, a portfolio of restoration commitments — describe it briefly,
        and we will come back to you with what the satellite record can establish.
      </p>
    </div>

    <form
      class="contact-form reveal"
      data-contact-form
      action={FORMSPREE_ENDPOINT}
      method="POST"
    >
      <div class="form-row">
        <div class="form-field">
          <label for="cf-name" class="label-caps">Name</label>
          <input id="cf-name" name="name" type="text" autocomplete="name" required />
        </div>
        <div class="form-field">
          <label for="cf-org" class="label-caps">Organisation</label>
          <input id="cf-org" name="organisation" type="text" autocomplete="organization" />
        </div>
      </div>
      <div class="form-field">
        <label for="cf-email" class="label-caps">Email</label>
        <input id="cf-email" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="form-field">
        <label for="cf-site" class="label-caps">Site or region</label>
        <input id="cf-site" name="site" type="text" placeholder="e.g. a lake in Devanahalli, Karnataka" />
      </div>
      <div class="form-field">
        <label for="cf-msg" class="label-caps">What would you like to establish?</label>
        <textarea id="cf-msg" name="message" rows="4"></textarea>
      </div>

      <!-- Submit button -->
      <button type="submit" class="btn btn-primary on-dark contact-submit" data-submit-btn>
        <span class="submit-label" data-label-default>Send request</span>
        <span class="submit-label submit-label--sending" data-label-sending aria-hidden="true">
          <svg class="spinner" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="36" stroke-dashoffset="12" />
          </svg>
          Sending…
        </span>
      </button>

      <!-- Status messages -->
      <div class="form-status" data-form-status aria-live="polite"></div>

      <!-- Subtle mailto fallback -->
      <p class="contact-alt">
        <a
          href={`mailto:${contactEmail}?subject=${encodeURIComponent('Assessment request — NEVARA')}`}
          class="contact-alt-link"
        >
          Prefer email? Write to us directly →
        </a>
      </p>
    </form>
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-forest);
    color: var(--color-cream);
  }

  .kicker {
    color: rgba(247, 246, 242, 0.55);
    margin-bottom: 24px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(48px, 7vw, 112px);
    align-items: start;
  }

  .contact-headline {
    font-size: clamp(2.5rem, 4.5vw, var(--text-section));
    color: var(--color-cream);
  }
  .contact-headline em {
    font-weight: 500;
    color: #a8c3b4;
  }

  .contact-lede {
    margin-top: 22px;
    color: rgba(247, 246, 242, 0.72);
    max-width: 44ch;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }

  .form-field label {
    display: block;
    color: rgba(247, 246, 242, 0.72);
    margin-bottom: 9px;
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    background: rgba(247, 246, 242, 0.07);
    border: 1px solid rgba(247, 246, 242, 0.18);
    border-radius: var(--radius-input);
    padding: 14px 18px;
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: var(--color-cream);
    transition: border-color 0.25s var(--ease-out-calm), background-color 0.25s var(--ease-out-calm);
  }
  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: rgba(247, 246, 242, 0.35);
  }
  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: rgba(247, 246, 242, 0.55);
    background: rgba(247, 246, 242, 0.1);
  }
  .form-field textarea {
    resize: vertical;
    min-height: 110px;
  }

  /* ── Submit button states ── */
  .contact-submit {
    align-self: flex-start;
    position: relative;
  }
  .contact-submit:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  .submit-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .submit-label--sending {
    display: none;
  }
  .contact-submit[data-sending] [data-label-default] {
    display: none;
  }
  .contact-submit[data-sending] .submit-label--sending {
    display: inline-flex;
  }

  .spinner {
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ── Status messages ── */
  .form-status {
    font-size: var(--text-small);
    line-height: 1.5;
    min-height: 0;
    transition: opacity 0.3s ease;
  }
  .form-status:empty {
    display: none;
  }
  .form-status--success {
    color: #a8c3b4;
  }
  .form-status--error {
    color: #e2a49a;
  }

  /* ── Subtle mailto fallback ── */
  .contact-alt {
    margin-top: -6px;
  }
  .contact-alt-link {
    font-size: var(--text-caption);
    color: rgba(247, 246, 242, 0.42);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .contact-alt-link:hover,
  .contact-alt-link:focus-visible {
    color: rgba(247, 246, 242, 0.72);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]')!;
  const submitBtn = form.querySelector<HTMLButtonElement>('[data-submit-btn]')!;
  const statusEl = form.querySelector<HTMLDivElement>('[data-form-status]')!;

  let isSending = false;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Prevent duplicate submissions
    if (isSending) return;

    // Client-side validation (HTML5 constraint API)
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    isSending = true;
    submitBtn.disabled = true;
    submitBtn.setAttribute('data-sending', '');
    statusEl.textContent = '';
    statusEl.className = 'form-status';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        statusEl.textContent =
          'Assessment request received. Our team will review your site and get back to you shortly.';
        statusEl.classList.add('form-status--success');
        form.reset();
      } else {
        const data = await response.json().catch(() => ({}));
        const msg =
          data?.errors?.map((err: { message: string }) => err.message).join(', ') ||
          'Something went wrong. Please try again.';
        statusEl.textContent = msg;
        statusEl.classList.add('form-status--error');
      }
    } catch {
      statusEl.textContent =
        'Network error — please check your connection and try again.';
      statusEl.classList.add('form-status--error');
    } finally {
      isSending = false;
      submitBtn.disabled = false;
      submitBtn.removeAttribute('data-sending');
    }
  });
</script>

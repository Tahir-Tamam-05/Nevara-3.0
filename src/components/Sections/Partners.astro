---
/**
 * Section 7 — Partners.
 * Real logos (client-supplied, Images/logos/), background removed, cropped
 * tight — never redrawn. Twin Glacier and SayTrees keep original color: a
 * flat monochrome recolor measurably hurt their recognizability (SayTrees'
 * identity is the black/green two-tone; Twin Glacier's line art faded to
 * near-invisible grey). Jala Poshan's source art is already black/white, so
 * it reads as monochrome without any alteration — all three stay faithful
 * to the delivered files.
 */
const partners = [
  { name: 'Twin Glacier Foundation', src: '/assets/partners/twin-glacier.png', h: 88 },
  { name: 'SayTrees', src: '/assets/partners/saytrees.png', h: 44 },
  { name: 'Jala Poshan', src: '/assets/partners/jalaposhan.png', h: 72 },
];
---

<section id="partners" class="section-pad" aria-labelledby="partners-heading">
  <div class="container-site reveal">
    <p class="label-caps kicker">In collaboration with</p>
    <h2 id="partners-heading" class="sr-only">Partners</h2>
    <ul class="partners-row">
      {
        partners.map(({ name, src, h }) => (
          <li class="partner-mark" style={`--mark-h: ${h}px`}>
            <img src={src} alt={name} loading="lazy" />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .kicker {
    color: var(--color-moss);
    margin-bottom: clamp(48px, 6vw, 88px);
    text-align: center;
  }

  .partners-row {
    list-style: none;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(48px, 9vw, 128px);
    flex-wrap: wrap;
  }

  /* Each mark gets its own calibrated height so the three read as visually
     balanced despite very different source aspect ratios — a circular
     emblem, a wide wordmark, and a tall badge cannot share one raw height
     without one of them dominating or vanishing. */
  .partner-mark {
    height: var(--mark-h);
    display: flex;
    align-items: center;
  }
  .partner-mark img {
    height: 100%;
    width: auto;
    max-width: 240px;
    object-fit: contain;
    opacity: 0.72;
    transition: opacity 0.3s var(--ease-out-calm);
  }
  .partner-mark img:hover {
    opacity: 1;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .partners-row {
      flex-direction: column;
      gap: 44px;
    }
    .partner-mark {
      height: calc(var(--mark-h) * 0.82);
    }
  }
</style>

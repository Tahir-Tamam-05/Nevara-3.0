---
import Layout from '../layouts/Layout.astro';
import Navbar from '@components/Navbar/Navbar.astro';
import PageHeader from '@components/PageHeader.astro';
import EvidenceShowcase from '@components/Sections/EvidenceShowcase.astro';
import ReportViewer from '@components/Reports/ReportViewer.astro';
import HowItWorks from '@components/Sections/HowItWorks.astro';
import Contact from '@components/Sections/Contact.astro';
import Footer from '@components/Footer/Footer.astro';
---

<Layout
  title="Reports — NEVARA"
  description="Actual NEVARA assessment reports: restoration intelligence, baselines and impact verification, built from the satellite record."
>
  <Navbar />
  <main id="main">
    <PageHeader
      kicker="Reports"
      headline="Evidence you can"
      headlineEm="hold to account."
      lede="Every engagement ends in a referenced, versioned document. Browse the actual reports NEVARA has delivered — page by page."
    />
    <EvidenceShowcase />
    <ReportViewer />
    <HowItWorks />
    <Contact />
  </main>
  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '@components/Navbar/Navbar.astro';
import PageHeader from '@components/PageHeader.astro';
import Contact from '@components/Sections/Contact.astro';
import Footer from '@components/Footer/Footer.astro';
import { companyInfo, contactEmail, partners } from '@lib/content';
import { Mail } from 'lucide-astro';
---

<Layout
  title="Contact — NEVARA"
  description="Request an environmental assessment from NEVARA — satellite-verified baselines, restoration intelligence and impact verification."
>
  <Navbar />
  <main id="main">
    <PageHeader
      kicker="Contact"
      headline="Start with"
      headlineEm="your site."
      lede="Describe the lake, forest or wetland you are responsible for. We will come back with what the satellite record can establish."
    />

    <Contact />

    <section class="section-pad info-section" aria-labelledby="info-heading">
      <div class="container-site info-grid">
        <div class="reveal">
          <p class="label-caps kicker">Contact information</p>
          <h2 id="info-heading" class="font-display info-headline">Reach us directly.</h2>
          <a href={`mailto:${contactEmail}`} class="info-email link-sweep">
            <Mail size={17} stroke-width={1.75} aria-hidden="true" />
            {contactEmail}
          </a>
          <p class="info-note">Assessments currently operate across Karnataka, India.</p>
        </div>
        <div class="reveal" data-reveal-delay="120">
          <p class="label-caps kicker">About {companyInfo.name}</p>
          <p class="info-full font-display">{companyInfo.fullName}</p>
          <p class="info-desc">{companyInfo.description}</p>
          <p class="info-partners label-caps">
            In partnership with {partners.join(' · ')}
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .kicker {
    color: var(--color-moss);
    margin-bottom: 20px;
  }
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(48px, 7vw, 112px);
    align-items: start;
  }
  .info-headline {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    margin-bottom: 24px;
  }
  .info-email {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--text-body-lg);
    font-weight: 500;
    color: var(--color-forest);
  }
  .info-note {
    margin-top: 18px;
    font-size: var(--text-small);
    color: rgba(16, 16, 16, 0.6);
  }
  .info-full {
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 16px;
  }
  .info-desc {
    color: rgba(16, 16, 16, 0.72);
    max-width: 48ch;
  }
  .info-partners {
    margin-top: 26px;
    color: rgba(16, 16, 16, 0.55);
  }

  @media (max-width: 820px) {
    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
